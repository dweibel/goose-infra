# Cloudflare Tunnel Configuration
# Obtain TUNNEL_TOKEN from Cloudflare dashboard after creating a tunnel
TUNNEL_TOKEN=your_tunnel_token_here

# Custom subdomain (informational - configured in Cloudflare dashboard)
TUNNEL_SUBDOMAIN=goose.example.com

# Goose AI Agent Configuration
# Mode: "interactive" for web terminal, "auto" for headless automation
GOOSE_MODE=interactive

# Context strategy: "default", "minimal", or "comprehensive"
GOOSE_CONTEXT_STRATEGY=default

# Maximum turns for headless mode (optional, default: 10)
GOOSE_MAX_TURNS=10

# AI Provider: "openai", "anthropic", etc.
GOOSE_PROVIDER=openai

# AI Provider API Key
GOOSE_API_KEY=your_api_key_here

# Container Configuration
# Internal port for ttyd (default: 7681)
TTYD_PORT=7681

# Logging level: "ERROR", "WARN", "INFO", "DEBUG"
LOG_LEVEL=INFO

# ============================================================================
# OCI Infrastructure Configuration
# ============================================================================

# OCI Authentication
# Required: Your OCI tenancy OCID from OCI Console (Identity > Tenancy Information)
# Format: ocid1.tenancy.oc1..aaaaaaaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_TENANCY_OCID=

# Required: Your OCI user OCID from OCI Console (Identity > Users > User Details)
# Format: ocid1.user.oc1..aaaaaaaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCI_USER_OCID=

# Required: Fingerprint of your OCI API key (shown when you upload the public key)
# Format: xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_FINGERPRINT=

# Required: Path to your OCI API private key file (PEM format)
# Example: ~/.oci/oci_api_key.pem or /path/to/oci_api_key.pem
OCI_PRIVATE_KEY_PATH=

# Required: OCI region identifier for resource deployment
# Examples: us-ashburn-1, us-phoenix-1, eu-frankfurt-1, ap-tokyo-1
# See: https://docs.oracle.com/en-us/iaas/Content/General/Concepts/regions.htm
OCI_REGION=

# Compartment Configuration
# Required: Target compartment OCID for resource provisioning
# Format: ocid1.compartment.oc1..aaaaaaaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Note: Use root compartment OCID for Always Free tier resources
OCI_COMPARTMENT_OCID=

# ============================================================================
# Wiki.js Configuration
# ============================================================================

# Required: Administrator email address for Wiki.js initial setup
# Format: valid email address
# Example: admin@example.com
WIKI_ADMIN_EMAIL=

# Required: Administrator password for Wiki.js login
# Security: Minimum 8 characters, use strong password with mixed case, numbers, symbols
# Example: MySecureP@ssw0rd!
WIKI_ADMIN_PASSWORD=

# Required: PostgreSQL database password for Wiki.js backend
# Security: Minimum 12 characters, use strong password with mixed case, numbers, symbols
# Note: This is internal to the podman pod, not exposed externally
POSTGRES_PASSWORD=

# ============================================================================
# MCP Server Configuration (Wiki Gateway Client)
# ============================================================================

# Wiki REST API Gateway URL (default: http://localhost:3001)
# The MCP server delegates all wiki operations to this gateway.
WIKI_GATEWAY_URL=http://localhost:3001

# Required: API key for authenticating with the Wiki API Gateway
# Use the read-only or read-write key configured on the gateway
WIKI_GATEWAY_API_KEY=

# Enable write operations (create, update, delete, move pages)
# Default: false (read-only: search, get, list)
ENABLE_WRITE_OPS=false

# ============================================================================
# ECR (AWS Elastic Container Registry) Configuration
# ============================================================================

# Required: AWS region where your ECR registry is located
# Examples: us-east-1, us-west-2, eu-west-1, ap-southeast-1
AWS_REGION=

# Required: AWS access key ID for ECR authentication
# Format: AKIA followed by 16 alphanumeric characters
# Example: AKIAIOSFODNN7EXAMPLE
# Security: Use IAM user with minimal permissions (ecr:GetAuthorizationToken, ecr:BatchGetImage)
AWS_ACCESS_KEY_ID=

# Required: AWS secret access key for ECR authentication
# Format: 40-character base64 string
# Security: Keep this secret secure, never commit to version control
AWS_SECRET_ACCESS_KEY=

# Required: ECR registry URL for container image pulls
# Format: <aws_account_id>.dkr.ecr.<region>.amazonaws.com
# Example: 123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REGISTRY=

# ============================================================================
# SSH Configuration
# ============================================================================

# Required: Path to SSH public key for OCI instance access
# Format: Path to .pub file
# Example: ~/.ssh/id_rsa.pub or ~/.ssh/oci_key.pub
# Note: This key will be added to authorized_keys on provisioned instances
SSH_PUBLIC_KEY_PATH=

# Required: Path to SSH private key for remote operations and deployments
# Format: Path to private key file (PEM or OpenSSH format)
# Example: ~/.ssh/id_rsa or ~/.ssh/oci_key
# Security: Ensure file permissions are 600 (chmod 600 <key_file>)
SSH_PRIVATE_KEY_PATH=


