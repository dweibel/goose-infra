FROM --platform=linux/arm64 node:20-alpine

WORKDIR /app

# Install dependencies (no production deps needed — uses built-in fetch)
COPY package*.json ./
RUN npm ci --omit=dev 2>/dev/null || true

# Copy application source
COPY src/ ./src/

# Stdio-only — no ports exposed, no health check endpoint
# Goose invokes this as: node src/server.js
CMD ["node", "src/server.js"]
