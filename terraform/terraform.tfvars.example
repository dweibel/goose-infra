# OCI Provider Configuration
# Copy this file to terraform.tfvars and fill in your values

# OCI Authentication
tenancy_ocid     = "ocid1.tenancy.oc1.."
user_ocid        = "ocid1.user.oc1.."
fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "us-ashburn-1"

# Compartment
compartment_id = "ocid1.compartment.oc1.."

# General Configuration
project_name = "oci-infra
"
name_prefix  = "oci"
environment  = "dev"

# Network Configuration
vcn_cidr           = "10.0.0.0/16"
subnet_cidr        = "10.0.1.0/24"
allowed_ssh_cidrs  = ["0.0.0.0/0"]  # Restrict this to your IP for security
allowed_http_cidrs = ["0.0.0.0/0"]  # Restrict this to your IP for security
extra_ports        = []              # Additional ports to open, e.g., [3000, 5432]

# Compute Configuration
availability_domain      = ""  # Leave empty to use first available AD
instance_shape           = "VM.Standard.A1.Flex"  # ARM64 Always Free tier
instance_ocpus           = 4   # Up to 4 OCPUs free
instance_memory_gb       = 24  # Up to 24 GB free
boot_volume_size_gb      = 200 # Up to 200 GB free
workspace_volume_size_gb = 50  # Persistent workspace storage
workspace_mount_path     = "/mnt/workspace"

# SSH Configuration
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2E... your-public-key-here"

# Application Configuration
app_port = 8080

# Logging Configuration
log_retention_days = 30

# Monitoring Configuration
alert_email = "your-email@example.com"
